async function addPropertyNote(id) {
  const input = document.getElementById(`note-input-${id}`);
  if (!input || !input.value.trim()) return;
  const text = input.value.trim();
  input.value = '';
  try {
    // Get current notes
    const res = await api(`/properties/${id}`);
    const p = res.data;
    let notes = [];
    try { notes = JSON.parse(p.notes || '[]'); } catch(e) { notes = []; }
    if (!Array.isArray(notes)) notes = [];
    // Add new note
    const now = new Date().toISOString();
    const author = user?.username || user?.name || user?.email || 'Unknown';
    notes.push({ id: Date.now(), content: text, author: author, date: now, tags: [author] });
    // Save via PATCH
    await api(`/properties/${id}`, { method:'PATCH', body:JSON.stringify({notes: JSON.stringify(notes)}) });
    showToast('Note added');
    // Re-render property detail
    showProperty(id);
  } catch(e) {
    showToast('Failed to add note: ' + e.message, 'error');
  }
}

