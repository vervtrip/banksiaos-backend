      html += '<div style="padding:12px;color:#555;font-size:12px;background:#000;border-radius:6px;margin-bottom:10px">No updates yet. Be the first to comment.</div>';
    } else {
      html += '<div style="max-height:300px;overflow-y:auto;margin-bottom:10px">';
      comments.forEach(c => {
        const hasMentions = c.mentions && c.mentions !== '[]';
        html += `<div style="padding:10px 12px;background:#000;border-radius:6px;margin-bottom:6px">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px">
