<script>
const user = {{ user | tojson | safe }};
const API = '/api/banksia-os';
const BASE = '/api';
const INITIAL_PAGE = '{{ initial_page }}' || '';
const INITIAL_RESOURCE_ID = '{{ initial_resource_id }}' || '';

// ── URL helpers ──
function pageUrl(page, resourceId) {
  if (!page || page === 'dashboard') return '/banksia-os';
  if (resourceId) return `/banksia-os/${page}/${resourceId}`;
  return `/banksia-os/${page}`;
}

function parseCurrentUrl() {
  // Parse current URL path to get page + resource_id
  const path = window.location.pathname;
  const match = path.match(/^\/banksia-os(?:\/([^\/]+)(?:\/([^\/]+))?)?$/);
  if (match) {
    return { page: match[1] || 'dashboard', resourceId: match[2] || '' };
  }
  return { page: 'dashboard', resourceId: '' };
}

// ── INIT ──
document.addEventListener('DOMContentLoaded', () => {
  document.getElementById('date-display').textContent = new Date().toLocaleDateString('en-GB', { weekday:'short', day:'numeric', month:'short', year:'numeric' });
  const role = user.role === 'super_admin' ? 'Super Admin' : (user.role === 'admin' ? 'Admin' : user.role);
  document.getElementById('sidebar-user-role').textContent = role;
  document.getElementById('topbar-user-role').textContent = role;
  // Read initial page from server or URL
  const urlInfo = parseCurrentUrl();
  const startPage = INITIAL_PAGE || urlInfo.page || 'dashboard';
  const startResourceId = INITIAL_RESOURCE_ID || urlInfo.resourceId || '';
  navigate(startPage, startResourceId);
});

// ── NAV ──
function navigate(page, resourceId) {
  document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
  const nav = document.querySelector(`.nav-item[data-page="${page}"]`);
  if (nav) nav.classList.add('active');
  if (window.innerWidth <= 768) {
    document.getElementById('sidebar').classList.remove('open');
    document.getElementById('sidebar-overlay').classList.remove('open');
  }
  closeDetail();
  currentPage = page;
  currentResourceId = resourceId || '';
  // Update URL with real path
  const url = pageUrl(page, resourceId || '');
  if (window.location.pathname !== url) {
    history.pushState({page: page, resourceId: resourceId || ''}, '', url);
  }
  renderPage(page, resourceId || '');
  // Auto-open detail panel if resourceId is provided
  if (resourceId) {
    const detailFns = {
      properties: showProperty, units: showUnit, tenancies: showTenancy,
      tenants: showTenant, applicants: showApplicant,
      'property-owners': showOwnerDetail, invoices: showInvoiceDetail,
      access: showAccessDetail
    };
    const fn = detailFns[page];
    if (fn) {
      const id = parseInt(resourceId) || resourceId;
      setTimeout(() => fn(id), 300);
    }
  }
}
// Listen for browser back/forward
window.addEventListener('popstate', (e) => {
  const urlInfo = parseCurrentUrl();
  const page = urlInfo.page;
  const resourceId = urlInfo.resourceId || '';
  document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
  const nav = document.querySelector(`.nav-item[data-page="${page}"]`);
  if (nav) nav.classList.add('active');
  closeDetail();
  currentPage = page;
  currentResourceId = resourceId;
  renderPage(page, resourceId);
  // Auto-open detail on back/forward navigation
  if (resourceId) {
    const detailFns = {
      properties: showProperty, units: showUnit, tenancies: showTenancy,
      tenants: showTenant, applicants: showApplicant,
      'property-owners': showOwnerDetail, invoices: showInvoiceDetail,
      access: showAccessDetail
    };
    const fn = detailFns[page];
    if (fn) {
      const id = parseInt(resourceId) || resourceId;
      setTimeout(() => fn(id), 300);
    }
  }
});
function toggleSidebar() {
  document.getElementById('sidebar').classList.toggle('open');
  document.getElementById('sidebar-overlay').classList.toggle('open');
}

// ── DETAIL ──
let currentPage = 'dashboard';
let currentResourceId = '';
function openDetail(title, html, page, resourceId) {
  document.getElementById('detail-title').textContent = title;
  document.getElementById('detail-body').innerHTML = html;
  document.getElementById('detail-overlay').classList.add('open');
  document.getElementById('detail-panel').classList.add('open');
  // Update URL with resource detail
  if (page && resourceId) {
    currentResourceId = resourceId;
    const url = pageUrl(page, resourceId);
    history.replaceState({page: page, resourceId: resourceId}, '', url);
  }
}
function closeDetail() {
  document.getElementById('detail-overlay').classList.remove('open');
  document.getElementById('detail-panel').classList.remove('open');
  // Restore URL to parent page
  if (currentResourceId) {
    currentResourceId = '';
    const url = pageUrl(currentPage, '');
    history.replaceState({page: currentPage, resourceId: ''}, '', url);
  }
}
function openModal(html) {
  document.getElementById('modal-inner').innerHTML = html;
  document.getElementById('modal-overlay').classList.add('open');
}
function closeModal(e) {
  // Allow Cancel buttons to close regardless of event source
  document.getElementById('modal-overlay').classList.remove('open');
}
function showToast(msg, type='success') {
  const t = document.getElementById('toast');
  t.textContent = msg; t.className = 'toast ' + type + ' show';
  setTimeout(() => t.classList.remove('show'), 3500);
}

// ── API ──
async function api(path, opts={}) {
  const res = await fetch(API + path, {
    headers: {'Content-Type':'application/json','Accept':'application/json'},
    ...opts
  });
  const data = await res.json();
  if (!data.success) throw new Error(data.error || 'API error');
  return data;
}

// ── FORMATTERS ──
function fmtDate(d) { if (!d) return '—'; try{return new Date(d).toLocaleDateString('en-GB')}catch(e){return d||'—'} }
function fmtDateISO(d) { if (!d) return '—'; try{return new Date(d).toLocaleString('en-GB',{day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'})}catch(e){return d} }
function fmtMoney(n) { if (n==null) return '—'; return '£' + Number(n).toLocaleString('en-GB', {minimumFractionDigits:2,maximumFractionDigits:2}) }
function fmtPct(n) { if (n==null) return '—'; return Number(n).toFixed(1) + '%' }
function statusBadge(s) {
  const map = {
    'active':'badge-active','inactive':'badge-inactive','pending':'badge-pending',
    'vacant':'badge-vacant','occupied':'badge-occupied','available':'badge-vacant','tenanted':'badge-occupied',
    'new':'badge-new','viewing':'badge-pending','application':'badge-pending','referencing':'badge-pending',
    'guarantor':'badge-pending','approved':'badge-approved','agreement':'badge-new','signature':'badge-new',
    'move in':'badge-active','move_in':'badge-active',
    'rejected':'badge-rejected','withdrawn':'badge-withdrawn',
    'current':'badge-active','periodic':'badge-periodic','past':'badge-inactive'
  };
  const cls = map[(s||'').toLowerCase()] || 'badge-pending';
  return `<span class="badge ${cls}">${escHtml(s||'Unknown')}</span>`;
}
function escHtml(s) { if (s==null) return ''; const d=document.createElement('div'); d.textContent=String(s); return d.innerHTML; }

// ── NOTIFICATION SYSTEM ──
let notifInterval = null;
async function loadNotifications() {
  try {
    const res = await api('/notifications');
    const d = res.data;
    const badge = document.getElementById('notif-badge');
    if (d.unread_count > 0) {
      badge.style.display = 'flex';
      badge.textContent = d.unread_count > 99 ? '99+' : d.unread_count;
