  } catch(e) {
    container.innerHTML = `<div class="detail-section"><h3>Updates</h3><div style="padding:12px;color:#ff1744;font-size:12px">Could not load: ${escHtml(e.message)}</div></div>`;
  }
  return container.innerHTML;
}

let acTimeout = null;
let acData = [];
async function loadAutocomplete() {
  if (acData.length === 0) {
    try { const r = await api('/users/autocomplete'); acData = r.data || []; } catch(e) { acData = []; }
  }
}
function commentAutocomplete(input, entityType, entityId) {
  clearTimeout(acTimeout);
  acTimeout = setTimeout(async () => {
    const val = input.value;
    const atIdx = val.lastIndexOf('@');
    if (atIdx === -1) { document.getElementById(`autocomplete-${entityType}-${entityId}`).style.display = 'none'; return; }
    const query = val.slice(atIdx + 1).toLowerCase();
    if (!query) { document.getElementById(`autocomplete-${entityType}-${entityId}`).style.display = 'none'; return; }
    await loadAutocomplete();
    const matches = acData.filter(u => u.toLowerCase().startsWith(query));
    const acEl = document.getElementById(`autocomplete-${entityType}-${entityId}`);
    if (matches.length === 0) { acEl.style.display = 'none'; return; }
    acEl.style.display = 'block';
    acEl.innerHTML = matches.map(u => `<div style="padding:8px 12px;font-size:12px;color:#ccc;cursor:pointer;border-bottom:1px solid rgba(255,255,255,.04)" onclick="selectAutocomplete('${u}','${entityType}',${entityId})" onmouseover="this.style.background='rgba(255,255,255,.06)'" onmouseout="this.style.background='transparent'">@${u}</div>`).join('');
  }, 200);
}
function selectAutocomplete(username, entityType, entityId) {
  const input = document.getElementById(`comment-input-${entityType}-${entityId}`);
  const lastAt = input.value.lastIndexOf('@');
  input.value = input.value.slice(0, lastAt) + `@${username} `;
  document.getElementById(`autocomplete-${entityType}-${entityId}`).style.display = 'none';
  input.focus();
}
async function postComment(entityType, entityId) {
  const input = document.getElementById(`comment-input-${entityType}-${entityId}`);
  if (!input || !input.value.trim()) return;
  const body = input.value.trim();
  input.value = '';
  try {
    await api(`/comments/${entityType}/${entityId}`, { method:'POST', body:JSON.stringify({body, author: user.username}) });
    // Refresh comments in the detail panel
    const section = document.getElementById(`comments-section-${entityType}-${entityId}`);
    if (section) section.innerHTML = await renderComments(entityType, entityId);
  } catch(e) {
    showToast('Failed to post: '+e.message, 'error');
  }
}
function linkify(text) {
  return text.replace(/@(\w+)/g, '<span style="color:#2563eb;font-weight:600">@$1</span>');
}

// Start notification polling after DOM loaded
document.addEventListener('DOMContentLoaded', () => {
  // existing init code runs first, then start notification polling
  setTimeout(() => {
    loadNotifications();
    setInterval(loadNotifications, 30000); // every 30s
  }, 500);
});

