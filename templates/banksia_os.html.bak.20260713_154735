// ══════════════════════════════════════════
// CREATE TENANCY FROM APPLICANT
// ══════════════════════════════════════════
async function createTenancyFromApplicant(applicantId) {
  try {
    const res = await api(`/applicants/${applicantId}`);
    const a = res.data;
    // Load properties and units for the form
    let props = [], units = [];
    try { const pr = await api('/properties?per_page=100'); props = pr.data||[]; } catch(e){}
    const propOpts = props.map(p => `<option value="${p.id}">${escHtml(p.ref||p.name||'#'+p.id)}</option>`).join('');
    openModal(`<h2>Create Tenancy</h2><div class="sub">Pre-filled from applicant: ${escHtml(a.first_name||'')} ${escHtml(a.last_name||'')}</div>
      <div class="form-group"><label>Tenant Name</label><input type="text" id="ct-name" value="${escHtml((a.first_name||'')+' '+(a.last_name||''))}"></div>
      <div class="form-row"><div class="form-group"><label>Email</label><input type="email" id="ct-email" value="${escHtml(a.email||'')}"></div>
      <div class="form-group"><label>Phone</label><input type="tel" id="ct-phone" value="${escHtml(a.phone||'')}"></div></div>
      <div class="form-group"><label>Property</label><select id="ct-property" onchange="loadUnitsForTenancy(this.value)">${propOpts}</select></div>
      <div class="form-group"><label>Unit</label><select id="ct-unit"><option value="">Select property first</option></select></div>
      <div class="form-row"><div class="form-group"><label>Rent (£/pcm)</label><input type="number" step="0.01" id="ct-rent" value="${a.annual_income?Math.round(a.annual_income/12):''}"></div>
      <div class="form-group"><label>Deposit (£)</label><input type="number" step="0.01" id="ct-deposit"></div></div>
      <div class="form-row"><div class="form-group"><label>Start Date</label><input type="date" id="ct-start"></div>
      <div class="form-group"><label>End Date</label><input type="date" id="ct-end"></div></div>
      <div class="form-actions"><button class="btn btn-cancel" onclick="closeModal(event)">Cancel</button>
      <button class="btn btn-submit" onclick="submitTenancyFromApplicant(${applicantId})">Create Tenancy</button></div>`);
  } catch(e) { showToast('Failed to load applicant: '+e.message,'error'); }
}
async function loadUnitsForTenancy(propertyId) {
  if (!propertyId) return;
  try {
    const res = await api(`/units?property_id=${propertyId}&per_page=100`);
    const units = res.data||[];
    const sel = document.getElementById('ct-unit');
    if (sel) sel.innerHTML = units.map(u => `<option value="${u.id}" data-rent="${u.market_rent||''}">${escHtml(u.unit_ref||'Unit #'+u.id)} — ${fmtMoney(u.market_rent)}</option>`).join('');
  } catch(e) {}
}
async function submitTenancyFromApplicant(applicantId) {
  const payload = {
    main_tenant_name: document.getElementById('ct-name').value,
    email: document.getElementById('ct-email').value,
    phone: document.getElementById('ct-phone').value,
    property_id: parseInt(document.getElementById('ct-property').value),
    unit_id: parseInt(document.getElementById('ct-unit').value)||null,
    rent_amount: parseFloat(document.getElementById('ct-rent').value)||0,
    deposit_amount: parseFloat(document.getElementById('ct-deposit').value)||0,
    start_date: document.getElementById('ct-start').value,
    end_date: document.getElementById('ct-end').value
  };
  if (!payload.main_tenant_name || !payload.property_id) { showToast('Tenant name and property required','error'); return; }
  try {
    await api('/tenancies', { method:'POST', body:JSON.stringify(payload) });
    // Optionally mark applicant as moved to tenancy
    if (applicantId) {
      await api(`/applicants/${applicantId}/status`, { method:'POST', body:JSON.stringify({status:'move_in'}) }).catch(()=>{});
    }
    closeModal(null); showToast('Tenancy created'); navigate('tenancies');
  } catch(e) { showToast('Failed: '+e.message,'error'); }
}

