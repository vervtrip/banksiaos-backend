// RENT SCHEDULE — Editable per-month charges
// ══════════════════════════════════════════
async function loadRentSchedule(tenancyId) {
  const area = document.getElementById(`rent-schedule-area-${tenancyId}`);
  if (!area) return;
  area.innerHTML = '<div class="loading" style="padding:10px"><div class="spinner"></div></div>';
  try {
    // Auto-generate charges if none exist yet
    await api(`/finance/rent-charges/generate/${tenancyId}`, { method:'POST' }).catch(() => {});
    const res = await api(`/finance/rent-charges/${tenancyId}`);
    const charges = res.data || [];
    if (charges.length === 0) {
      area.innerHTML = '<div style="padding:12px;color:#555;font-size:12px">No rent charges generated yet.</div>';
      return;
    }
    let html = `<div style="max-height:400px;overflow-y:auto;border:1px solid #222;border-radius:8px;background:#000">
      <table style="width:100%;border-collapse:collapse"><thead><tr>
        <th style="padding:8px 10px;font-size:10px;color:#666;text-transform:uppercase;text-align:left;border-bottom:1px solid #333;position:sticky;top:0;background:#000">Month</th>
        <th style="padding:8px 10px;font-size:10px;color:#666;text-transform:uppercase;text-align:right;border-bottom:1px solid #333;position:sticky;top:0;background:#000">Rent</th>
        <th style="padding:8px 10px;font-size:10px;color:#666;text-transform:uppercase;text-align:right;border-bottom:1px solid #333;position:sticky;top:0;background:#000">Paid</th>
        <th style="padding:8px 10px;font-size:10px;color:#666;text-transform:uppercase;text-align:center;border-bottom:1px solid #333;position:sticky;top:0;background:#000">Status</th>
        <th style="padding:8px 10px;font-size:10px;color:#666;text-transform:uppercase;text-align:center;border-bottom:1px solid #333;position:sticky;top:0;background:#000"></th>
      </tr></thead><tbody>`;
    let totalExpected = 0, totalPaid = 0;
    charges.forEach(c => {
      totalExpected += c.rent_amount;
      totalPaid += c.paid_amount;
      const statusColor = c.status === 'paid' ? '#00c853' : (c.status === 'overdue' ? '#ff1744' : '#ffab00');
      html += `<tr>
        <td style="padding:8px 10px;font-size:12px;color:#ccc;border-bottom:1px solid rgba(255,255,255,.04)"><strong>${escHtml(c.month)}</strong></td>
        <td style="padding:8px 10px;font-size:12px;text-align:right;border-bottom:1px solid rgba(255,255,255,.04)">
          <input type="number" step="0.01" id="rc-amount-${c.id}" value="${c.rent_amount}" style="width:80px;padding:4px 6px;border-radius:4px;border:1px solid #333;background:#111;color:#fff;font-size:11px;text-align:right"
            onchange="updateRentCharge(${c.id},'rent_amount',this.value)">
        </td>
        <td style="padding:8px 10px;font-size:12px;text-align:right;border-bottom:1px solid rgba(255,255,255,.04)">
          <input type="number" step="0.01" id="rc-paid-${c.id}" value="${c.paid_amount}" style="width:80px;padding:4px 6px;border-radius:4px;border:1px solid #333;background:#111;color:#fff;font-size:11px;text-align:right"
            onchange="updateRentCharge(${c.id},'paid_amount',this.value)">
        </td>
        <td style="padding:8px 10px;font-size:12px;text-align:center;border-bottom:1px solid rgba(255,255,255,.04)">
          <span style="color:${statusColor}">${escHtml(c.status)}</span>
        </td>
        <td style="padding:8px 10px;font-size:12px;text-align:center;border-bottom:1px solid rgba(255,255,255,.04)">
          <select style="padding:3px 4px;border-radius:4px;border:1px solid #333;background:#111;color:#fff;font-size:10px" onchange="updateRentCharge(${c.id},'status',this.value)">
            <option value="due" ${c.status==='due'?'selected':''}>Due</option>
            <option value="paid" ${c.status==='paid'?'selected':''}>Paid</option>
            <option value="overdue" ${c.status==='overdue'?'selected':''}>Overdue</option>
            <option value="partial" ${c.status==='partial'?'selected':''}>Partial</option>
          </select>
        </td>
      </tr>`;
    });
    html += `</tbody></table></div>
    <div style="display:flex;justify-content:space-between;padding:10px 0;font-size:12px;color:#888">
      <span>Expected: <strong style="color:#fff">${fmtMoney(totalExpected)}</strong></span>
      <span>Paid: <strong style="color:#00c853">${fmtMoney(totalPaid)}</strong></span>
      <span>Balance: <strong style="color:${(totalExpected-totalPaid)>0?'#ffab00':'#00c853'}">${fmtMoney(totalExpected-totalPaid)}</strong></span>
    </div>`;
    area.innerHTML = html;
  } catch(e) {
    area.innerHTML = `<div style="padding:12px;color:#ff1744;font-size:12px">Failed: ${escHtml(e.message)}</div>`;
  }
}

let rcTimer = null;
async function updateRentCharge(chargeId, field, value) {
  clearTimeout(rcTimer);
  rcTimer = setTimeout(async () => {
    try {
      const res = await api(`/finance/rent-charges/${chargeId}`, {
        method:'PATCH',
        body: JSON.stringify({[field]: parseFloat(value) || value})
      });
      // Update summary below the table
      const d = res.data;
      const area = document.getElementById(`rent-schedule-area-${d.charge_id}`);
      // Show toast with updated totals
      showToast(`Updated — Balance: ${fmtMoney(d.balance)}`);
    } catch(e) {
      showToast('Update failed: '+e.message, 'error');
    }
  }, 400);
}

