// Editable detail field
function makeEditable(table, id, field, label, val, type='text') {
  return `<div class="detail-field">
    <div class="label">${label}</div>
    <div class="val" id="val-${table}-${id}-${field}" onclick="editField('${table}',${id},'${field}','${label}','${escHtml(String(val||''))}','${type}')">${escHtml(val||'—')}</div>
  </div>`;
}
function editField(table, id, field, label, currentVal, type) {
  const el = document.getElementById(`val-${table}-${id}-${field}`);
  if (!el) return;
  const input = type==='select' ? `<select id="edit-input">${currentVal}</select>` :
    type==='number' ? `<input type="number" step="0.01" id="edit-input" value="${currentVal}">` :
    `<input type="text" id="edit-input" value="${currentVal}" placeholder="${label}">`;
  el.innerHTML = input + `<button class="save-btn" onclick="saveField('${table}',${id},'${field}')">Save</button><button class="cancel-btn" onclick="cancelEdit('${table}',${id},'${field}','${escHtml(currentVal)}')">Cancel</button>`;
  const inp = document.getElementById('edit-input');
  if (inp) inp.focus();
}
function cancelEdit(table, id, field, origVal) {
  const el = document.getElementById(`val-${table}-${id}-${field}`);
  if (el) el.innerHTML = escHtml(origVal||'—');
}
async function saveField(table, id, field) {
  const inp = document.getElementById('edit-input');
  if (!inp) return;
  const val = inp.value;
  try {
    await api(`/${table}/${id}`, { method:'PATCH', body:JSON.stringify({[field]: val}) });
    showToast('Updated ✓');
    // Close detail and re-open
    const fn = { properties: showProperty, units: showUnit, tenancies: showTenancy, tenants: showTenant }[table];
    if (fn) { closeDetail(); setTimeout(() => fn(id), 200); }
  } catch(e) {
    showToast('Failed: ' + e.message, 'error');
  }
}

