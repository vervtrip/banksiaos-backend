            <span style="font-size:10px;color:#555">${fmtDateISO(c.created)}</span>
          </div>
          <div style="font-size:12px;color:#ccc;line-height:1.5">${linkify(escHtml(c.body))}</div>
        </div>`;
      });
      html += '</div>';
    }
    // Comment input
    html += `<div style="display:flex;gap:8px">
      <input type="text" id="comment-input-${entityType}-${entityId}" placeholder="Write an update... Use @name to mention someone" style="flex:1;padding:10px 12px;border-radius:6px;border:1px solid #333;background:#000;color:#fff;font-size:12px;font-family:'Inter',sans-serif;outline:none"
        onkeydown="if(event.key==='Enter'){postComment('${entityType}',${entityId})}"
        oninput="commentAutocomplete(this,'${entityType}',${entityId})">
      <button class="btn btn-primary btn-sm" onclick="postComment('${entityType}',${entityId})">Post</button>
    </div>
    <div id="autocomplete-${entityType}-${entityId}" style="display:none;background:#111;border:1px solid #333;border-radius:6px;margin-top:4px;max-height:120px;overflow-y:auto"></div>`;
    html += '</div>';
