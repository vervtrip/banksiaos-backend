<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Banksia OS</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Ctext y='28' font-size='28'%3E🌿%3C/text%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Inter',-apple-system,sans-serif;background:#f1f5f9;color:#1e293b;min-height:100vh;display:flex;overflow-x:hidden;-webkit-font-smoothing:antialiased}
a{color:#334155;text-decoration:none}

/* SIDEBAR */
.sidebar{width:240px;background:#1e293b;display:flex;flex-direction:column;position:fixed;top:0;left:0;bottom:0;z-index:100;transform:translateX(0);transition:transform .2s ease;border-right:1px solid rgba(255,255,255,.06)}
.sidebar .brand{padding:20px 24px 16px;border-bottom:1px solid rgba(255,255,255,.06)}
.sidebar .brand h1{font-size:22px;font-weight:800;color:#fff;letter-spacing:-0.5px}
.sidebar .brand .tagline{font-size:10px;color:#64748b;text-transform:uppercase;letter-spacing:3px;margin-top:4px}
.sidebar .nav{padding:8px 0;flex:1;overflow-y:auto}
.sidebar .nav-item{display:flex;align-items:center;gap:12px;padding:11px 24px;color:#94a3b8;font-size:13px;font-weight:500;cursor:pointer;transition:all .12s;border-left:3px solid transparent}
.sidebar .nav-item:hover{color:#fff;background:rgba(255,255,255,.06)}
.sidebar .nav-item.active{color:#fff;background:rgba(255,255,255,.1);border-left-color:#fff}
.sidebar .nav-item .icon{font-size:14px;width:20px;text-align:center;flex-shrink:0;opacity:.7}
.sidebar .nav-item.active .icon{opacity:1}
.sidebar .nav-item .badge{background:#fff;color:#1e293b;font-size:10px;padding:2px 7px;border-radius:8px;margin-left:auto;font-weight:600}
.sidebar .user-section{padding:16px 24px;border-top:1px solid rgba(255,255,255,.06);font-size:12px;color:#64748b}
.sidebar .user-section .name{color:#fff;font-weight:600;font-size:13px}

/* MAIN */
.main{margin-left:240px;flex:1;min-height:100vh;display:flex;flex-direction:column;background:#f1f5f9}
.topbar{background:#fff;padding:16px 32px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid #e2e8f0;position:sticky;top:0;z-index:50;min-height:64px}
.topbar .left{display:flex;align-items:center;gap:16px}
.topbar .hamburger{display:none;background:none;border:none;color:#94a3b8;font-size:20px;cursor:pointer;padding:4px}
.topbar .hamburger:hover{color:#1e293b}
.topbar .page-title{font-size:18px;font-weight:700;color:#1e293b;letter-spacing:-0.3px}
.topbar .page-subtitle{font-size:12px;color:#94a3b8;margin-top:2px}
.topbar .right{display:flex;align-items:center;gap:16px}
.topbar .user-info{text-align:right}
.topbar .user-info .name{font-size:13px;font-weight:600;color:#1e293b}
.topbar .user-info .role{font-size:11px;color:#94a3b8}
.topbar .date-display{font-size:12px;color:#64748b;padding:6px 12px;border:1px solid #e2e8f0;border-radius:6px;background:#f8fafc}
.content{padding:32px;flex:1}

/* KPI CARDS */
.kpi-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px;margin-bottom:28px}
.kpi-card{background:#fff;border:1px solid #e2e8f0;border-radius:12px;padding:20px;transition:all .15s;cursor:pointer;position:relative;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.04)}
.kpi-card:hover{border-color:#cbd5e1;background:#fafafa}
.kpi-card .label{font-size:10px;color:#94a3b8;text-transform:uppercase;letter-spacing:1.2px;margin-bottom:8px;font-weight:500}
.kpi-card .value{font-size:28px;font-weight:700;color:#1e293b;letter-spacing:-0.5px;line-height:1.1}
.kpi-card .sub{font-size:12px;color:#64748b;margin-top:6px}
.kpi-card .value.green{color:#16a34a}
.kpi-card .value.red{color:#dc2626}
.kpi-card .value.amber{color:#d97706}
.kpi-card .value.blue{color:#2563eb}
.kpi-accent{position:absolute;top:0;left:0;width:4px;height:100%}
.kpi-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:12px}
.kpi-icon{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}

/* TABLES */
.table-wrap{background:#fff;border:1px solid #e2e8f0;border-radius:12px;overflow:hidden;margin-bottom:20px;box-shadow:0 1px 3px rgba(0,0,0,.04)}
.table-toolbar{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid #e2e8f0;gap:12px;flex-wrap:wrap}
.table-toolbar .left{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.table-toolbar .right{display:flex;align-items:center;gap:10px}
.table-toolbar .ttl{font-size:14px;font-weight:600;color:#1e293b}
.table-toolbar .ttl-sub{font-size:12px;color:#94a3b8}
input,select{padding:8px 12px;border-radius:8px;border:1px solid #e2e8f0;background:#fff;color:#1e293b;font-size:13px;font-family:'Inter',sans-serif;outline:none}
input:focus,select:focus{border-color:#6366f1;box-shadow:0 0 0 3px rgba(99,102,241,.1)}
input::placeholder{color:#94a3b8}
.btn{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:8px;font-size:12px;font-weight:500;font-family:'Inter',sans-serif;cursor:pointer;transition:all .12s;border:none;letter-spacing:0.2px}
.btn-primary{background:#1e293b;color:#fff}
.btn-primary:hover{background:#334155}
.btn-success{background:#16a34a;color:#fff}
.btn-success:hover{background:#15803d}
.btn-danger{background:#dc2626;color:#fff}
.btn-danger:hover{background:#b91c1c}
.btn-ghost{background:transparent;color:#64748b;border:1px solid #e2e8f0}
.btn-ghost:hover{background:#f1f5f9;color:#1e293b;border-color:#cbd5e1}
.btn-amber{background:#d97706;color:#fff}
.btn-amber:hover{background:#b45309}
.btn-sm{padding:6px 12px;font-size:11px}
table{width:100%;border-collapse:collapse}
thead th{text-align:left;padding:10px 16px;font-size:10px;font-weight:600;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;border-bottom:1px solid #e2e8f0;white-space:nowrap;cursor:pointer;user-select:none;background:#f8fafc}
thead th:hover{color:#64748b}
tbody td{padding:10px 16px;font-size:13px;border-bottom:1px solid #f1f5f9;vertical-align:middle;color:#475569}
tbody tr{cursor:pointer;transition:background .1s}
tbody tr:hover{background:#f8fafc}
tbody tr:last-child td{border-bottom:none}
.pagination{display:flex;align-items:center;justify-content:space-between;padding:12px 20px;font-size:12px;color:#94a3b8}
.pagination .page-btn{padding:5px 10px;border-radius:4px;border:1px solid #e2e8f0;background:#fff;color:#64748b;cursor:pointer;font-size:11px;font-family:'Inter',sans-serif}
.pagination .page-btn:disabled{opacity:.4;cursor:not-allowed}
.pagination .page-btn:hover:not(:disabled){background:#f1f5f9}

/* BADGES */
.badge{display:inline-block;padding:2px 8px;border-radius:4px;font-size:10px;font-weight:600;letter-spacing:0.3px}
.badge-active{background:#f0fdf4;color:#16a34a}
.badge-inactive{background:#f8fafc;color:#64748b}
.badge-pending{background:#fffbeb;color:#d97706}
.badge-vacant{background:#fef2f2;color:#dc2626}
.badge-occupied{background:#f0fdf4;color:#16a34a}
.badge-approved{background:#f0fdf4;color:#16a34a}
.badge-rejected{background:rgba(220,38,38,.1);color:#dc2626}
.badge-withdrawn{background:#f8fafc;color:#64748b}
.badge-periodic{background:#eff6ff;color:#2563eb}
.badge-new{background:#eff6ff;color:#2563eb}

/* DETAIL PANEL — slide from right */
.detail-overlay{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(15,23,42,.5);z-index:200}
.detail-overlay.open{display:block}
.detail-panel{position:fixed;top:0;right:-620px;width:600px;max-width:100vw;bottom:0;background:#fff;border-left:1px solid #e2e8f0;z-index:201;transition:right .25s ease;overflow-y:auto}
.detail-panel.open{right:0}
.detail-header{display:flex;justify-content:space-between;align-items:center;padding:20px 24px;border-bottom:1px solid #e2e8f0;position:sticky;top:0;background:#fff;z-index:2}
.detail-header h2{font-size:16px;font-weight:700;color:#1e293b}
.detail-header .close-btn{background:none;border:none;color:#94a3b8;font-size:20px;cursor:pointer;padding:4px 8px;border-radius:4px}
.detail-header .close-btn:hover{color:#1e293b;background:#f1f5f9}
.detail-body{padding:24px}
.detail-section{margin-bottom:28px}
.detail-section h3{font-size:11px;font-weight:600;color:#64748b;text-transform:uppercase;letter-spacing:1.2px;margin-bottom:12px}
.detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.detail-field{position:relative}
.detail-field .label{font-size:10px;color:#94a3b8;margin-bottom:2px;text-transform:uppercase;letter-spacing:.5px}
.detail-field .val{font-size:13px;color:#475569;word-break:break-word;padding:2px 0}
.detail-field .val.full{grid-column:1/-1}
.detail-field .val a{color:#2563eb}
.detail-field .val a:hover{text-decoration:underline}
.detail-field input,.detail-field select{width:100%;padding:6px 8px;border-radius:6px;border:1px solid #e2e8f0;background:#fff;color:#1e293b;font-size:12px;font-family:'Inter',sans-serif;outline:none;margin-top:2px}
.detail-field input:focus,.detail-field select:focus{border-color:#6366f1;box-shadow:0 0 0 3px rgba(99,102,241,.1)}
.detail-field .edit-btn{position:absolute;top:0;right:0;background:none;border:none;color:#94a3b8;font-size:10px;cursor:pointer;padding:2px 4px;border-radius:3px}
.detail-field .edit-btn:hover{color:#1e293b;background:#f1f5f9}
.detail-field .save-btn{background:#1e293b;color:#fff;border:none;padding:4px 10px;border-radius:4px;font-size:10px;font-weight:600;cursor:pointer;margin-top:4px}
.detail-field .save-btn:hover{background:#334155}
.detail-field .cancel-btn{background:transparent;color:#64748b;border:1px solid #e2e8f0;padding:4px 10px;border-radius:4px;font-size:10px;cursor:pointer;margin-top:4px;margin-left:4px}
.detail-field .cancel-btn:hover{color:#1e293b;background:#f1f5f9}

/* MODAL */
.modal-overlay{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(15,23,42,.6);z-index:300;align-items:center;justify-content:center}
.modal-overlay.open{display:flex}
.modal{background:#fff;border:1px solid #e2e8f0;border-radius:16px;width:520px;max-width:90vw;max-height:90vh;overflow-y:auto;padding:32px;box-shadow:0 20px 60px rgba(15,23,42,.15)}
.modal h2{font-size:18px;font-weight:700;color:#1e293b;margin-bottom:4px}
.modal .sub{font-size:13px;color:#64748b;margin-bottom:24px}
.modal .form-group{margin-bottom:16px}
.modal .form-group label{display:block;font-size:11px;font-weight:500;color:#64748b;margin-bottom:4px;text-transform:uppercase;letter-spacing:.5px}
.modal .form-group input,.modal .form-group select,.modal .form-group textarea{width:100%;padding:10px 12px;border-radius:8px;border:1px solid #e2e8f0;background:#fff;color:#1e293b;font-size:13px;font-family:'Inter',sans-serif;outline:none}
.modal .form-group input:focus,.modal .form-group select:focus,.modal .form-group textarea:focus{border-color:#6366f1;box-shadow:0 0 0 3px rgba(99,102,241,.1)}
.modal .form-group textarea{resize:vertical;min-height:60px}
.modal .form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.modal .form-actions{display:flex;gap:10px;justify-content:flex-end;margin-top:24px}
.modal .btn-cancel{background:transparent;color:#64748b;border:1px solid #e2e8f0;padding:10px 20px;border-radius:8px;font-size:13px;font-weight:500;font-family:'Inter',sans-serif;cursor:pointer}
.modal .btn-cancel:hover{color:#1e293b;background:#f1f5f9}
.modal .btn-submit{background:#1e293b;color:#fff;padding:10px 20px;border-radius:8px;font-size:13px;font-weight:600;font-family:'Inter',sans-serif;cursor:pointer;border:none}
.modal .btn-submit:hover{background:#334155}

/* PIPELINE — applicant kanban */
.pipeline{display:flex;gap:10px;overflow-x:auto;padding-bottom:16px;min-height:50vh}
.pipeline-col{flex:0 0 200px;min-width:180px;background:#fff;border:1px solid #e2e8f0;border-radius:12px;padding:12px;display:flex;flex-direction:column}
.pipeline-col .col-header{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:1px;color:#64748b;margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid #e2e8f0;display:flex;justify-content:space-between}
.pipeline-col .col-header .count{background:#f1f5f9;padding:2px 7px;border-radius:4px;font-size:10px;color:#64748b}
.pipeline-card{background:#fff;border:1px solid #e2e8f0;border-radius:8px;padding:10px 12px;margin-bottom:6px;cursor:pointer;transition:all .12s}
.pipeline-card:hover{border-color:#cbd5e1;box-shadow:0 1px 3px rgba(0,0,0,.06)}
.pipeline-card .name{font-size:12px;font-weight:600;color:#1e293b}
.pipeline-card .meta{font-size:10px;color:#64748b;margin-top:4px;display:flex;flex-direction:column;gap:2px}

/* SEARCH */
.search-bar{display:flex;gap:8px;margin-bottom:24px}
.search-bar input{flex:1;padding:12px 16px;border-radius:8px;border:1px solid #e2e8f0;background:#fff;color:#1e293b;font-size:15px;font-family:'Inter',sans-serif;outline:none}
.search-bar input:focus{border-color:#6366f1;box-shadow:0 0 0 3px rgba(99,102,241,.1)}
.search-group{margin-bottom:24px}
.search-group h3{font-size:13px;font-weight:600;color:#64748b;margin-bottom:10px;text-transform:capitalize}
.search-item{padding:10px 14px;background:#fff;border:1px solid #e2e8f0;border-radius:8px;margin-bottom:4px;cursor:pointer;transition:all .12s}
.search-item:hover{border-color:#cbd5e1;box-shadow:0 1px 3px rgba(0,0,0,.04)}
.search-item .title{font-size:13px;font-weight:600;color:#1e293b}
.search-item .desc{font-size:11px;color:#64748b;margin-top:2px}

/* FINANCE CARDS */
.finance-cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:12px;margin-bottom:24px}
.finance-card{background:#fff;border:1px solid #e2e8f0;border-radius:12px;padding:20px;box-shadow:0 1px 3px rgba(0,0,0,.04)}
.finance-card .label{font-size:10px;color:#94a3b8;text-transform:uppercase;letter-spacing:1.2px;margin-bottom:6px}
.finance-card .value{font-size:24px;font-weight:700;color:#1e293b}
.finance-card .value.green{color:#16a34a}
.finance-card .value.red{color:#dc2626}

/* LOADING / EMPTY / TOAST */
.loading{display:flex;align-items:center;justify-content:center;padding:60px 20px;color:#94a3b8;font-size:14px}
.spinner{width:18px;height:18px;border:2px solid #e2e8f0;border-top-color:#6366f1;border-radius:50%;animation:spin .6s linear infinite;margin-right:10px}
@keyframes spin{to{transform:rotate(360deg)}}
.empty-state{text-align:center;padding:60px 20px;color:#94a3b8}
.empty-state .icon{font-size:40px;margin-bottom:12px;opacity:.4}
.empty-state h3{color:#64748b;font-size:15px;margin-bottom:4px;font-weight:500}
.empty-state p{font-size:13px}

.toast{position:fixed;bottom:24px;right:24px;padding:12px 20px;border-radius:8px;font-size:13px;font-weight:500;z-index:999;opacity:0;transform:translateY(10px);transition:all .25s;max-width:400px}
.toast.show{opacity:1;transform:translateY(0)}
.toast.success{background:#16a34a;color:#fff}
.toast.error{background:#dc2626;color:#fff}
.toast.info{background:#475569;color:#fff}

/* RENT COLLECTION */
.rent-collection{display:flex;flex-direction:column;gap:8px}
.rent-collection .rc-header{display:flex;justify-content:space-between;font-size:13px;color:#64748b}
.rent-collection .rc-header .rc-collected{color:#16a34a;font-weight:600}
.rent-collection .rc-header .rc-expected{color:#94a3b8}
.rent-collection .rc-bar{height:8px;background:#f1f5f9;border-radius:4px;overflow:hidden}
.rent-collection .rc-bar .rc-fill{height:100%;border-radius:4px;transition:width .6s ease;background:linear-gradient(90deg,#16a34a,#4ade80)}
.rent-collection .rc-bar .rc-fill.warning{background:linear-gradient(90deg,#d97706,#fbbf24)}
.rent-collection .rc-bar .rc-fill.danger{background:linear-gradient(90deg,#dc2626,#f87171)}
.rent-collection .rc-stats{display:flex;justify-content:space-between;font-size:11px;color:#94a3b8;margin-top:2px}
.rent-collection .rc-stats .rc-pct{font-weight:600;color:#475569}

/* ALERTS */
.alert-item{display:flex;align-items:center;gap:12px;padding:12px 20px;border-bottom:1px solid #f1f5f9;cursor:pointer;transition:all .12s}
.alert-item:last-child{border-bottom:none}
.alert-item:hover{background:#f8fafc}
.alert-item .alert-icon{width:30px;height:30px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0}
.alert-item .alert-icon.warning{background:#fffbeb;color:#d97706}
.alert-item .alert-icon.danger{background:#fef2f2;color:#dc2626}
.alert-item .alert-icon.info{background:#eff6ff;color:#2563eb}
.alert-item .alert-body{flex:1}
.alert-item .alert-body .alert-title{font-size:13px;font-weight:600;color:#1e293b}
.alert-item .alert-body .alert-desc{font-size:11px;color:#64748b;margin-top:2px}
.alert-item .alert-action{font-size:11px;color:#2563eb;font-weight:500;white-space:nowrap}

/* RENEWAL ITEMS */
.renewal-item{display:flex;align-items:center;gap:12px;padding:10px 16px;border-bottom:1px solid #f1f5f9;cursor:pointer;transition:all .12s}
.renewal-item:last-child{border-bottom:none}
.renewal-item:hover{background:#f8fafc}
.renewal-item .renewal-info{flex:1}
.renewal-item .renewal-info .renewal-tenant{font-size:13px;font-weight:600;color:#1e293b}
.renewal-item .renewal-info .renewal-meta{font-size:11px;color:#64748b;margin-top:2px}
.renewal-item .renewal-date{font-size:12px;color:#d97706;white-space:nowrap}

/* RESPONSIVE — full mobile support */

/* SIDEBAR OVERLAY for mobile — click to close */
.sidebar-overlay{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(15,23,42,.5);z-index:99}

/* MOBILE OVERFLOW FIX — no horizontal scroll, no zoom needed */
@media(max-width:768px){
  html,body{overflow-x:hidden;width:100%;}
  .sidebar-overlay.open{display:block}
  .main{margin-left:0;width:100%;max-width:100vw;overflow-x:hidden}
  .sidebar{transform:translateX(-100%);max-width:75vw;width:280px;box-shadow:none;z-index:100}
  .sidebar.open{transform:translateX(0);box-shadow:0 0 30px rgba(0,0,0,.5)}
  .nav-item{padding:14px 20px;font-size:14px;min-height:48px}
  .topbar .right .date-display{display:none!important}
  .kpi-grid{grid-template-columns:1fr 1fr;gap:8px}
  .kpi-card{padding:14px;min-height:auto}
  .kpi-card .value{font-size:20px;word-break:break-word}
  .table-wrap{overflow-x:auto;width:100%;-webkit-overflow-scrolling:touch}
  table{min-width:auto;width:100%;font-size:13px}
  thead th,tbody td{padding:8px 10px;font-size:12px;white-space:normal;word-break:break-word}
  .table-toolbar{flex-direction:column;gap:8px;padding:12px 14px}
  .table-toolbar .left,.table-toolbar .right{width:100%}
  .table-toolbar input,.table-toolbar select{width:100%!important;font-size:16px;min-height:44px}
  .btn{padding:12px 18px;font-size:14px;min-height:44px}
  .detail-panel{width:100vw;right:-100vw}
  .detail-grid{grid-template-columns:1fr}
  .detail-header{padding:14px 16px;min-height:56px}
  .detail-body{padding:14px}
  .form-row{grid-template-columns:1fr!important}
  .pipeline{flex-direction:column;overflow-x:hidden}
  .pipeline-col{flex:1 1 auto;min-width:auto}
  .finance-cards{grid-template-columns:1fr 1fr;gap:8px}
  .modal{width:95vw;padding:20px;margin:0 auto}
  .modal .form-row{grid-template-columns:1fr!important}
  .search-bar{flex-direction:column;gap:8px}
  .search-bar input{width:100%;font-size:16px;min-height:44px}
  .content{padding:10px;max-width:100vw}
  .topbar{padding:10px 14px;min-height:56px}
  .topbar .page-title{font-size:16px}
  .topbar .hamburger{display:block;font-size:24px;padding:8px;min-width:44px;min-height:44px}
  .notif-btn{padding:8px 10px!important}
  .notif-dropdown{width:100vw!important;right:-14px!important;border-radius:0!important;max-height:50vh}
  .rent-collection .rc-header{flex-direction:column;gap:4px}
  .msg-layout{flex-direction:column;height:auto!important}
  .msg-threads{width:100%!important;max-height:200px}
