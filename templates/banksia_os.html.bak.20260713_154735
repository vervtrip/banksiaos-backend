let searchTerm = '';
async function renderSearch() {
  const el = document.getElementById('page-content');
  el.innerHTML = `<div class="search-bar"><input id="search-input" placeholder="Search properties, tenancies, tenants, applicants..." value="${escHtml(searchTerm)}" onkeyup="if(event.key==='Enter'){searchTerm=this.value;doSearch()}"><button class="btn btn-primary" onclick="searchTerm=document.getElementById('search-input').value;doSearch()">Search</button></div><div id="search-results"></div>`;
  if (searchTerm) doSearch();
}
async function doSearch() {
  const el = document.getElementById('search-results');
  if (!searchTerm) { el.innerHTML = '<div class="empty-state"><div class="icon">⌕</div><h3>Enter a search term</h3></div>'; return; }
  el.innerHTML = '<div class="loading"><div class="spinner"></div>Searching...</div>';
  try {
    const res = await api(`/search?q=${encodeURIComponent(searchTerm)}&type=all`);
    const data = res.data || {};
    const groups = ['properties','units','tenancies','tenants','applicants'];
    let html = ''; let total = 0;
    groups.forEach(key => {
      const items = data[key] || [];
      total += items.length;
      if (items.length > 0) {
        html += `<div class="search-group"><h3>${key.charAt(0).toUpperCase()+key.slice(1)} (${items.length})</h3>`;
        items.forEach(item => {
          let title='', desc='';
          if (key==='properties') { title=item.name||item.ref||''; desc=item.address_line_1+', '+item.city; }
          else if (key==='units') { title=item.unit_ref||item.full_address||''; desc=item.unit_type+' — '+fmtMoney(item.market_rent); }
          else if (key==='tenancies') { title=item.main_tenant_name||item.ref||''; desc=item.full_address+' | '+fmtMoney(item.rent_amount); }
          else if (key==='tenants') { title=(item.first_name||'')+' '+(item.last_name||''); desc=item.email||item.phone||''; }
          else if (key==='applicants') { title=(item.first_name||'')+' '+(item.last_name||''); desc=item.property_interest||item.email||''; }
          html += `<div class="search-item" onclick="navigateToResult('${key}',${item.id})"><div class="title">${escHtml(title||'—')}</div><div class="desc">${escHtml(desc||'')}</div></div>`;
        });
        html += '</div>';
      }
    });
    if (total===0) html = '<div class="empty-state"><div class="icon">⌕</div><h3>No results</h3><p>No matches for "'+escHtml(searchTerm)+'"</p></div>';
    el.innerHTML = html;
  } catch(e) { el.innerHTML = `<div class="empty-state"><div class="icon">⚠</div><h3>Search failed</h3><p>${escHtml(e.message)}</p></div>`; }
}
function navigateToResult(type, id) {
  const map = { properties:'properties', units:'units', tenancies:'tenancies', tenants:'tenants', applicants:'applicants' };
  const page = map[type] || 'search';
  navigate(page, id);
}

