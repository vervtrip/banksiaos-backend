      const occ = d.unit_occupancy_rate||0;
      if (occ < 70 && occ > 0) alerts.push({icon:'danger', emoji:'◧', title:`Occupancy at ${fmtPct(occ)}`, desc:'Below 70% — market vacant units', action:'View Units', nav:'units'});
      let html = '';
