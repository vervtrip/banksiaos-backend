    html += '<div><label style="display:block;font-size:11px;color:#888;margin-bottom:4px">Tenancy ID</label><input type="number" id="gen-tenancy" placeholder="ID" style="width:100px"></div>';
    html += '<div><button class="btn btn-primary btn-sm" onclick="generateDocument()">Generate</button></div>';
    html += '</div></div></div>';

