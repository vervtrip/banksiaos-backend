async function cancelInvoice(id) {
  if (!confirm('Cancel this invoice?')) return;
  try { await api(`/invoices/${id}`, { method:'DELETE' }); showToast('Invoice cancelled'); closeDetail(); renderInvoices(); }
  catch(e) { showToast('Failed: '+e.message,'error'); }
}
function showNewInvoiceForm() {
  openModal(`<h2>New Invoice</h2><div class="sub">Create a tenant invoice</div>
    <div class="form-group"><label>Tenant Name</label><input type="text" id="newinv-tenant"></div>
    <div class="form-group"><label>Property</label><input type="text" id="newinv-property"></div>
    <div class="form-row"><div class="form-group"><label>Amount (£)</label><input type="number" step="0.01" id="newinv-amount"></div>
    <div class="form-group"><label>Due Date</label><input type="date" id="newinv-duedate"></div></div>
    <div class="form-group"><label>Description</label><textarea id="newinv-desc" rows="2" placeholder="e.g. Rent for July 2026"></textarea></div>
    <div class="form-actions"><button class="btn btn-cancel" onclick="closeModal(event)">Cancel</button>
    <button class="btn btn-submit" onclick="submitNewInvoice()">Create</button></div>`);
}
async function submitNewInvoice() {
  const payload = {
    tenant_name: document.getElementById('newinv-tenant').value,
    property_name: document.getElementById('newinv-property').value,
    amount: parseFloat(document.getElementById('newinv-amount').value)||0,
    due_date: document.getElementById('newinv-duedate').value,
    description: document.getElementById('newinv-desc').value
  };
  if (!payload.tenant_name||!payload.amount) { showToast('Tenant name and amount required','error'); return; }
  try { await api('/invoices', { method:'POST', body:JSON.stringify(payload) }); closeModal(null); showToast('Invoice created'); renderInvoices(); }
  catch(e) { showToast('Failed: '+e.message,'error'); }
}

// ══════════════════════════════════════════
// SETTINGS — Company profile
// ══════════════════════════════════════════
async function renderSettings() {
  const el = document.getElementById('page-content');
  el.innerHTML = '<div class="loading"><div class="spinner"></div>Loading settings...</div>';
  try {
    const res = await api('/company-settings');
    const s = res.data || {};
    el.innerHTML = `<div class="settings-form">
      <h3 style="font-size:13px;font-weight:600;color:#fff;margin-bottom:16px">Company Profile</h3>
      <div class="form-row">
        <div class="form-group"><label>Company Name</label><input type="text" id="set-company-name" value="${escHtml(s.company_name||s.name||'')}"></div>
        <div class="form-group"><label>Registration No</label><input type="text" id="set-reg" value="${escHtml(s.registration_number||s.reg_no||'')}"></div>
      </div>
      <div class="form-group"><label>Address</label><input type="text" id="set-address" value="${escHtml(s.address||s.address_line_1||'')}"></div>
      <div class="form-row">
        <div class="form-group"><label>City</label><input type="text" id="set-city" value="${escHtml(s.city||'')}"></div>
        <div class="form-group"><label>Postcode</label><input type="text" id="set-postcode" value="${escHtml(s.postcode||'')}"></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label>VAT / Tax ID</label><input type="text" id="set-vat" value="${escHtml(s.vat_number||s.vat||'')}"></div>
        <div class="form-group"><label>Phone</label><input type="tel" id="set-phone" value="${escHtml(s.phone||s.phone_number||'')}"></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label>Email</label><input type="email" id="set-email" value="${escHtml(s.email||'')}"></div>
        <div class="form-group"><label>Website</label><input type="url" id="set-website" value="${escHtml(s.website||'')}"></div>
      </div>
      <div class="form-actions">
        <button class="btn btn-primary" onclick="saveSettings()">Save Changes</button>
      </div>
    </div>`;
  } catch(e) {
    el.innerHTML = `<div class="empty-state"><div class="icon">⚠</div><h3>Failed to load settings</h3><p>${escHtml(e.message)}</p></div>`;
  }
}
async function saveSettings() {
  const payload = {
    company_name: document.getElementById('set-company-name').value,
    registration_number: document.getElementById('set-reg').value,
    address: document.getElementById('set-address').value,
    city: document.getElementById('set-city').value,
    postcode: document.getElementById('set-postcode').value,
    vat_number: document.getElementById('set-vat').value,
    phone: document.getElementById('set-phone').value,
    email: document.getElementById('set-email').value,
    website: document.getElementById('set-website').value
  };
  try {
    await api('/company-settings', { method:'POST', body:JSON.stringify(payload) });
    showToast('Settings saved ✓');
  } catch(e) { showToast('Failed: '+e.message,'error'); }
}

