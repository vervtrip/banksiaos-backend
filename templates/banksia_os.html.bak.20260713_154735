function renderFileUploadZone(entityType, entityId, entityName) {
  const zoneId = `dropzone-${entityType}-${entityId}`;
  return `<div class="detail-section"><h3>Files</h3>
    <div id="${zoneId}" style="border:2px dashed #333;border-radius:8px;padding:20px;text-align:center;cursor:pointer;background:#0a0a0a;margin-bottom:8px"
      ondragover="event.preventDefault();this.style.borderColor='#fff'"
      ondragleave="this.style.borderColor='#333'"
      ondrop="handleFileDrop(event,'${entityType}',${entityId})"
      onclick="document.getElementById('file-input-${entityType}-${entityId}').click()">
      <div style="font-size:24px;margin-bottom:8px;opacity:.5">📄</div>
      <div style="font-size:12px;color:#666">Drop files here or click to browse</div>
      <div style="font-size:10px;color:#555;margin-top:4px">PDF, DOCX, JPG, PNG</div>
      <input type="file" id="file-input-${entityType}-${entityId}" multiple accept=".pdf,.doc,.docx,.jpg,.jpeg,.png" style="display:none"
        onchange="handleFileSelect(event,'${entityType}',${entityId})">
    </div>
    <div id="files-list-${entityType}-${entityId}"><div class="loading" style="padding:10px"><div class="spinner"></div></div></div>
  </div>`;
}

async function loadEntityFiles(entityType, entityId) {
  try {
    const res = await api(`/documents/uploaded`);
    const allDocs = res.data || [];
    const docs = allDocs.filter(d => d.related_to === entityType && String(d.related_id) === String(entityId));
    const list = document.getElementById(`files-list-${entityType}-${entityId}`);
    if (!list) return;
    if (docs.length === 0) {
      list.innerHTML = '<div style="padding:8px;color:#555;font-size:11px">No files attached yet.</div>';
      return;
    }
    let html = '';
    docs.forEach(d => {
      html += `<div style="display:flex;justify-content:space-between;align-items:center;padding:6px 8px;background:#000;border-radius:4px;margin-bottom:4px;font-size:11px">
        <span style="color:#ccc">📄 ${escHtml(d.filename)}</span>
        <span><button class="btn btn-ghost btn-sm" onclick="window.open('${API}/documents/uploaded/${d.id}/download','_blank')" style="padding:2px 6px;font-size:9px">⬇</button></span>
      </div>`;
    });
    list.innerHTML = html;
  } catch(e) {
    const list = document.getElementById(`files-list-${entityType}-${entityId}`);
    if (list) list.innerHTML = '<div style="padding:8px;color:#555;font-size:11px">Could not load files</div>';
  }
}

async function handleFileDrop(e, entityType, entityId) {
  e.preventDefault();
  e.target.style.borderColor = '#333';
  const files = Array.from(e.dataTransfer.files);
  await uploadEntityFiles(files, entityType, entityId);
}
async function handleFileSelect(e, entityType, entityId) {
  const files = Array.from(e.target.files);
  await uploadEntityFiles(files, entityType, entityId);
  e.target.value = '';
}
async function uploadEntityFiles(files, entityType, entityId) {
  for (const file of files) {
    const fd = new FormData();
    fd.append('file', file);
    fd.append('category', 'general');
    fd.append('related_to', entityType);
    fd.append('related_id', String(entityId));
    fd.append('notes', `Uploaded from ${entityType} profile`);
    fd.append('auto_match', 'false');
    try {
      await fetch(API+'/documents/upload', { method:'POST', body:fd });
    } catch(e) {
      showToast('Failed to upload '+file.name, 'error');
    }
  }
  showToast(`${files.length} file(s) uploaded`);
  await loadEntityFiles(entityType, entityId);
}
