let msgState = { threads:[], selectedThread:null, messages:[], search:'', taskDetails:null };
function fmtTimeDate(d) {
  if (!d) return '—';
  try {
    const dt = new Date(d);
    const now = new Date();
    const isToday = dt.toDateString() === now.toDateString();
    const time = dt.toLocaleTimeString('en-GB', {hour:'2-digit',minute:'2-digit'});
    if (isToday) return time;
    const yesterday = new Date(now); yesterday.setDate(yesterday.getDate()-1);
    if (dt.toDateString() === yesterday.toDateString()) return 'Yesterday ' + time;
    return dt.toLocaleDateString('en-GB', {day:'numeric',month:'short'}) + ' ' + time;
  } catch(e) { return d; }
}
async function renderMessages() { try { const res = await api('/threads'); msgState.threads = res.data || []; const el = document.getElementById('page-content'); el.innerHTML = buildMessagesLayout(); renderThreadList(); } catch(e) { document.getElementById('page-content').innerHTML = '<div class="empty-state" style="padding:40px"><div class="icon">✉</div><h3>Failed to load threads</h3><p>'+escHtml(e.message)+'</p></div>'; } }
function buildMessagesLayout() { return '<div class="msg-layout"><div class="msg-threads"><div class="msg-toolbar"><button onclick="showNewThreadForm()">+ New Thread</button><span class="spacer"></span><button onclick="document.getElementById(\'msg-thread-search-input\').focus()">🔍</button></div><div class="thread-search"><input placeholder="Search threads..." id="msg-thread-search-input" value="'+escHtml(msgState.search)+'" onkeyup="if(event.key===\'Enter\'){msgState.search=this.value;renderThreadList()}"></div><div class="msg-thread-list" id="msg-thread-list"></div></div><div class="msg-conversation" id="msg-conversation"><div class="msg-header" id="msg-conv-header">Select a thread</div><div class="msg-body" id="msg-conv-body"><div class="empty-state" style="padding:40px"><div class="icon">✉</div><h3>Select a conversation</h3></div></div><div class="msg-input-area" id="msg-input-area" style="display:none"><button class="attach-btn" onclick="document.getElementById(\'msg-file-input\').click()" title="Attach file">📎</button><input type="file" id="msg-file-input" style="display:none" onchange="attachFile(this)"><input type="text" id="msg-reply-input" placeholder="Type a message..." onkeyup="if(event.key===\'Enter\')sendMessage()" autocomplete="off"><button class="btn btn-primary btn-sm" onclick="sendMessage()">Send</button></div></div><div class="msg-task-panel" id="msg-task-panel"><div class="empty-state" style="padding:20px"><div class="icon">☰</div><h3>Task Details</h3><p style="font-size:11px;color:#555">Select a thread to view</p></div></div></div>'; }
function renderThreadList() { const list = document.getElementById('msg-thread-list'); if (!list) return; const search = msgState.search.toLowerCase(); const filtered = msgState.threads.filter(t => (t.subject||t.title||'').toLowerCase().includes(search) || (t.participants||[]).some(p => (p||'').toLowerCase().includes(search))); if (filtered.length === 0) { list.innerHTML = '<div style="padding:20px;text-align:center;color:#555;font-size:12px">No threads found</div>'; return; } list.innerHTML = filtered.map(t => { const id = t.id||t.thread_id; const isActive = msgState.selectedThread && (msgState.selectedThread.id === id); const lm = t.last_message||{}; const preview = lm.body||t.preview||''; const lmAuthor = lm.author ? (lm.author+': ') : ''; return '<div class="msg-thread-item '+(isActive?'active':'')+'" onclick="selectThread(\''+id+'\')"><div class="thread-name">'+escHtml(t.subject||t.title||'Untitled')+'</div><div class="thread-preview">'+escHtml(lmAuthor+preview)+'</div><div class="thread-meta"><span>'+escHtml((t.participants||[]).join(', '))+'</span><span>'+fmtTimeDate(t.last_updated||t.updated_at)+'</span></div></div>'; }).join(''); }
async function selectThread(id) { const t = msgState.threads.find(t => (t.id||t.thread_id) == id); if (!t) return; msgState.selectedThread = t; renderThreadList(); const header = document.getElementById('msg-conv-header'); const body = document.getElementById('msg-conv-body'); const inputArea = document.getElementById('msg-input-area'); if (header) header.textContent = escHtml(t.subject||t.title||'Conversation'); if (body) body.innerHTML = '<div class="loading"><div class="spinner"></div>Loading messages...</div>'; if (inputArea) inputArea.style.display = 'flex'; try { const res = await api('/threads/'+id); const msgs = res.data?.messages||[]; msgState.messages = msgs; renderMessagesToBody(body); renderTaskPanel(t); } catch(e) { if(body) body.innerHTML = '<div class="empty-state" style="padding:20px"><div class="icon">⚠</div><h3>Failed to load messages</h3></div>'; } }
function renderMessagesToBody(body) { if(!body) return; if(msgState.messages.length===0) { body.innerHTML = '<div class="empty-state" style="padding:20px"><p style="color:#555;font-size:13px">No messages yet. Start the conversation.</p></div>'; return; } const currentUser = (user?.username||user?.name||'').toLowerCase(); body.innerHTML = msgState.messages.map(m => { const msgAuthor = (m.author||m.sender||m.from||'').toLowerCase(); const isSent = msgAuthor===currentUser||msgAuthor==='me'||m.is_me||m.author_role==='team'; const isDeleted = m.is_deleted==1; const isEdited = m.edited==1; const msgId = m.id; if(isDeleted) return '<div class="msg-deleted">[This message was deleted]</div>'; return '<div class="msg-bubble '+(isSent?'sent':'received')+'" style="position:relative">'+(isSent?'<div class="msg-actions"><button onclick="editMessage('+msgId+',event)" title="Edit">✏️</button><button class="danger" onclick="deleteMessage('+msgId+',event)" title="Delete">🗑️</button></div>':'')+'<div class="msg-text" id="msg-text-'+msgId+'">'+escHtml(m.body||m.message||m.content||'')+(isEdited?'<span class="msg-edited">(edited)</span>':'')+'</div><div class="msg-time">'+(isSent?'You':escHtml(m.author||m.sender||m.from||'Unknown'))+' · '+fmtTimeDate(m.created_at||m.timestamp||m.created)+'</div></div>'; }).join(''); body.scrollTop = body.scrollHeight; }
async function editMessage(id, event) { if(event) event.stopPropagation(); const textEl = document.getElementById('msg-text-'+id); if(!textEl) return; const currentText = textEl.textContent.replace(/\s*\(edited\)\s*$/,''); textEl.innerHTML = '<textarea class="edit-textarea" id="edit-input-'+id+'">'+escHtml(currentText)+'</textarea><div class="edit-actions"><button class="save-btn" onclick="saveEdit('+id+')">Save</button><button class="cancel-btn" onclick="cancelEdit('+id+',\''+escHtml(currentText).replace(/'/g,"\\'")+'\')">Cancel</button></div>'; document.getElementById('edit-input-'+id).focus(); }
async function saveEdit(id) { const input = document.getElementById('edit-input-'+id); if(!input||!input.value.trim()) return; try { await api('/messages/'+id, {method:'PATCH', body:JSON.stringify({body: input.value.trim()})}); const tid = msgState.selectedThread?.id||msgState.selectedThread?.thread_id; if(tid) { const res = await api('/threads/'+tid); msgState.messages = res.data?.messages||[]; renderMessagesToBody(document.getElementById('msg-conv-body')); } showToast('Message updated'); } catch(e) { showToast('Failed to edit: '+e.message,'error'); } }
