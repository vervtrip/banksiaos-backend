function attachFile(input) { if(!input||!input.files||!input.files[0]) return; showToast('Attached: '+input.files[0].name); input.value = ''; }
function renderTaskPanel(thread) { const panel = document.getElementById('msg-task-panel'); if(!panel) return; let html = '<div class="task-label">Subject</div><div class="task-value">'+escHtml(thread.subject||thread.title||'—')+'</div>'; html += '<div class="task-label">Participants</div><div class="task-value">'+escHtml((thread.participants||[]).join(', ')||'—')+'</div>'; html += '<div class="task-label">Status</div><div class="task-value">'+statusBadge(thread.status||'active')+'</div>'; html += '<div class="task-label">Priority</div><div class="task-value">'+escHtml(thread.priority||'Normal')+'</div>'; html += '<div class="task-label">Messages</div><div class="task-value">'+(thread.message_count||0)+'</div>'; html += '<div class="task-label">Last Updated</div><div class="task-value">'+fmtTimeDate(thread.last_updated||thread.updated_at)+'</div>'; html += '<div class="task-label">Notes</div><div class="task-value">'+escHtml(thread.notes||'—')+'</div>'; if(thread.assigned_to) html += '<div class="task-label">Assigned To</div><div class="task-value">'+escHtml(thread.assigned_to)+'</div>'; panel.innerHTML = html; }
